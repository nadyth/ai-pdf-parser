# --- App ---
APP_NAME=pdf-parser
APP_ENV=dev
LOG_LEVEL=INFO

# Comma-separated. Any key here gates the API and UI.
API_KEYS=dev-local-key

# --- Database ---
# Use postgres in docker / aiosqlite locally
DATABASE_URL=postgresql+asyncpg://pdf:pdf@postgres:5432/pdfparser
# DATABASE_URL=sqlite+aiosqlite:///./storage/pdfparser.db

# --- Redis / arq ---
REDIS_URL=redis://redis:6379/0

# --- Storage ---
STORAGE_ROOT=/data/storage
PDF_RENDER_DPI=300

# --- LLM providers (litellm) ---
# Mirrors model_routes.yaml api_key_env fields
OLLAMA_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# --- Upload + processing limits (sized for whole-book parsing) ---
MAX_UPLOAD_BYTES=2147483648         # 2 GiB
MAX_PAGES=1000                       # hard reject anything bigger
PAGE_CONCURRENCY=4                   # parallel page LLM workers
KEEP_PAGE_IMAGES=true                # set false to delete PNGs after a page is parsed
RULE_CHUNK_PAGES=40                  # chunk rule extraction over this many pages at a time
PARSE_JOB_TIMEOUT_SECONDS=21600      # 6 hours

# --- LLM retry ---
LLM_MAX_ATTEMPTS=5
LLM_BACKOFF_BASE_SECONDS=2.0

# --- Webhooks / callbacks ---
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=5
WEBHOOK_BACKOFF_BASE_SECONDS=2.0
